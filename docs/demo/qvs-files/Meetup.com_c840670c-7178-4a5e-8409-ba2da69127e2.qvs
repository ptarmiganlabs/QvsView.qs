///$tab Init
SET ThousandSep=',';
SET DecimalSep='.';
SET MoneyThousandSep=',';
SET MoneyDecimalSep='.';
SET MoneyFormat='$#,##0.00;-$#,##0.00';
SET TimeFormat='h:mm:ss TT';
SET DateFormat='M/D/YYYY';
SET TimestampFormat='M/D/YYYY h:mm:ss[.fff] TT';
SET FirstWeekDay=6;
SET BrokenWeeks=1;
SET ReferenceDay=0;
SET FirstMonthOfYear=1;
SET CollationLocale='en-US';
SET CreateSearchIndexOnReload=1;
SET MonthNames='Jan;Feb;Mar;Apr;May;Jun;Jul;Aug;Sep;Oct;Nov;Dec';
SET LongMonthNames='January;February;March;April;May;June;July;August;September;October;November;December';
SET DayNames='Mon;Tue;Wed;Thu;Fri;Sat;Sun';
SET LongDayNames='Monday;Tuesday;Wednesday;Thursday;Friday;Saturday;Sunday';

///$tab Healthcheck
Sub Healthcheck(healthcheckId)
    LIB CONNECT TO 'Healthcheck';

    let remoteURL = 'http://healthcheck.ptarmiganlabs.net:8000/ping/$(healthcheckId)';

    RestConnectorMasterTable:
    SQL SELECT 
        "col_1"
    FROM CSV (header off, delimiter ",", quote """") "CSV_source"
    WITH CONNECTION(Url "$(remoteURL)");
    ;

    // Uncomment if you are interested in the result that came back from the healthcheck service
    //   [CSV_source]:
    //   LOAD	
    //   	[col_1]
    //   RESIDENT RestConnectorMasterTable;

    DROP TABLE RestConnectorMasterTable;
End Sub



Sub HealthcheckStart(healthcheckId)
    LIB CONNECT TO 'Healthcheck';

    let remoteURL = 'http://healthcheck.ptarmiganlabs.net:8000/ping/$(healthcheckId)/start';

    RestConnectorMasterTable:
    SQL SELECT 
        "col_1"
    FROM CSV (header off, delimiter ",", quote """") "CSV_source"
    WITH CONNECTION(Url "$(remoteURL)");
    ;

    // Uncomment if you are interested in the result that came back from the healthcheck service
    //   [CSV_source]:
    //   LOAD	
    //   	[col_1]
    //   RESIDENT RestConnectorMasterTable;

    DROP TABLE RestConnectorMasterTable;
End Sub


///$tab Signal job start
let vHealthcheckUUID = '10a887bf-4580-4891-9c6f-2affbd380f16';

call HealthcheckStart('$(vHealthcheckUUID)')

///$tab Load data
Set dataManagerTables = '','events','venues','cities','groups','categories','members','topics','groups_topics';
//This block renames script tables from non generated section which conflict with the names of managed tables

For each name in $(dataManagerTables) 
    Let index = 0;
    Let currentName = name; 
    Let tableNumber = TableNumber(name); 
    Let matches = 0; 
    Do while not IsNull(tableNumber) or (index > 0 and matches > 0)
        index = index + 1; 
        currentName = name & '-' & index; 
        tableNumber = TableNumber(currentName) 
        matches = Match('$(currentName)', $(dataManagerTables));
    Loop 
    If index > 0 then 
            Rename Table '$(name)' to '$(currentName)'; 
    EndIf; 
Next; 
Set dataManagerTables = ;


Unqualify *;

__countryAliasesBase:
LOAD
	Alias AS [__Country],
	ISO3Code AS [__ISO3Code]
FROM [lib://AttachedFiles/countryAliases.qvd]
(qvd);

__countryGeoBase:
LOAD
	ISO3Code AS [__ISO3Code],
	ISO2Code AS [__ISO2Code],
	Polygon AS [__Polygon]
FROM [lib://AttachedFiles/countryGeo.qvd]
(qvd);

__cityAliasesBase:
LOAD
	Alias AS [__City],
	geoKey AS [__geoKey],
	CountryCode AS [__CityCountryCode]
FROM [lib://AttachedFiles/cityAliases.qvd]
(qvd);

__cityGeoBase:
LOAD
	geoKey AS [__geoKey],
	geoPoint AS [__GeoPoint]
FROM [lib://AttachedFiles/cityGeo.qvd]
(qvd);

__countryName2IsoThree:
MAPPING LOAD
	__Country,
	__ISO3Code
RESIDENT __countryAliasesBase;

__countryCodeIsoThree2Polygon:
MAPPING LOAD
	__ISO3Code,
	__Polygon
RESIDENT __countryGeoBase;

__countryCodeAndCityName2Key:
MAPPING LOAD
	__CityCountryCode & __City,
	__geoKey
RESIDENT __cityAliasesBase;

__cityKey2GeoPoint:
MAPPING LOAD
	__geoKey,
	__GeoPoint
RESIDENT __cityGeoBase;

[events]:
LOAD
	[event_id],
	[created],
	[description],
	[duration],
	[event_url],
	[fee.accepts],
	[fee.amount],
	[fee.currency],
	[fee.description],
	[fee.label],
	[fee.required],
	[group.created],
	[group.group_lat],
	[group.group_lon],
	[group_id],
	[group.join_mode],
	[group.name],
	[group.urlname],
	[group.who],
	[headcount],
	[how_to_find_us],
	[maybe_rsvp_count],
	[event_name],
	[photo_url],
	[rating.average],
	[rating.count],
	[rsvp_limit],
	[event_status],
	[event_time],
	[updated],
	[utc_offset] AS [events.utc_offset],
	[venue.address_1],
	[venue.address_2],
	[venue.city],
	[venue.country],
	[venue_id],
	[venue.lat],
	[venue.localized_country_name],
	[venue.lon],
	[venue.name],
	[venue.phone],
	[venue.repinned],
	[venue.state],
	[venue.zip],
	[visibility],
	[waitlist_count],
	[why],
	[yes_rsvp_count],
	APPLYMAP( '__countryCodeIsoThree2Polygon', APPLYMAP( '__countryName2IsoThree', LOWER([venue.country])), '-') AS [events.venue.country_GeoInfo],
	APPLYMAP( '__countryCodeIsoThree2Polygon', APPLYMAP( '__countryName2IsoThree', LOWER([venue.localized_country_name])), '-') AS [events.venue.localized_country_name_GeoInfo];
LOAD
	[event_id],
	[created],
	[description],
	[duration],
	[event_url],
	[fee.accepts],
	[fee.amount],
	[fee.currency],
	[fee.description],
	[fee.label],
	[fee.required],
	[group.created],
	[group.group_lat],
	[group.group_lon],
	[group_id],
	[group.join_mode],
	[group.name],
	[group.urlname],
	[group.who],
	[headcount],
	[how_to_find_us],
	[maybe_rsvp_count],
	[event_name],
	[photo_url],
	[rating.average],
	[rating.count],
	[rsvp_limit],
	[event_status],
	[event_time],
	[updated],
	[utc_offset],
	[venue.address_1],
	[venue.address_2],
	[venue.city],
	[venue.country],
	[venue_id],
	[venue.lat],
	[venue.localized_country_name],
	[venue.lon],
	[venue.name],
	[venue.phone],
	[venue.repinned],
	[venue.state],
	[venue.zip],
	[visibility],
	[waitlist_count],
	[why],
	[yes_rsvp_count]
 FROM [lib://Test data/meetupcom\events.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);

[countryMapping]:
MAPPING LOAD * INLINE
[
countryMapping-FROM,countryMapping-TO
us,US
];
[stateMapping]:
MAPPING LOAD * INLINE
[
stateMapping-FROM,stateMapping-TO
Ka,KA
Ca,KA
Il,KA
Ne,KA
];
[venues]:
LOAD
	[venue_id],
	[address_1],
	[city] AS [venues.city],
	APPLYMAP( 'countryMapping', [country]) AS [country],
	[distance],
	[lat],
	[localized_country_name],
	[lon],
	[venue_name],
	[rating],
	[rating_count],
	APPLYMAP( 'stateMapping', [state]) AS [state],
	[zip],
	[normalised_rating],
	APPLYMAP( '__countryCodeIsoThree2Polygon', APPLYMAP( '__countryName2IsoThree', LOWER(APPLYMAP( 'countryMapping', [country]))), '-') AS [venues.country_GeoInfo],
	APPLYMAP( '__countryCodeIsoThree2Polygon', APPLYMAP( '__countryName2IsoThree', LOWER([localized_country_name])), '-') AS [venues.localized_country_name_GeoInfo],
	GeoMakePoint([lat], [lon]) AS [venue_location],
	APPLYMAP( '__cityKey2GeoPoint', APPLYMAP( '__countryCodeAndCityName2Key', APPLYMAP( '__countryName2IsoThree', LOWER([country])) & LOWER([venue_name])), '-') AS [venues.venue_name_GeoInfo];
LOAD
	[venue_id],
	[address_1],
	[city],
	[country],
	[distance],
	[lat],
	[localized_country_name],
	[lon],
	[venue_name],
	[rating],
	[rating_count],
	[state],
	[zip],
	[normalised_rating]
 FROM [lib://Test data/meetupcom\venues.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);

[cities]:
LOAD
	[city] AS [cities.city],
	[city_id],
	[country] AS [cities.country],
	[distance] AS [cities.distance],
	[latitude],
	[localized_country_name] AS [cities.localized_country_name],
	[longitude],
	[member_count],
	[ranking],
	[state] AS [cities.state],
	[zip] AS [cities.zip],
	APPLYMAP( '__cityKey2GeoPoint', APPLYMAP( '__countryCodeAndCityName2Key', APPLYMAP( '__countryName2IsoThree', LOWER([country])) & LOWER([city])), '-') AS [cities.cities.city_GeoInfo],
	APPLYMAP( '__countryCodeIsoThree2Polygon', APPLYMAP( '__countryName2IsoThree', LOWER([country])), '-') AS [cities.cities.country_GeoInfo],
	APPLYMAP( '__countryCodeIsoThree2Polygon', APPLYMAP( '__countryName2IsoThree', LOWER([localized_country_name])), '-') AS [cities.cities.localized_country_name_GeoInfo],
	GeoMakePoint([latitude], [longitude]) AS [longitude_latitude];
LOAD
	[city],
	[city_id],
	[country],
	[distance],
	[latitude],
	[localized_country_name],
	[longitude],
	[member_count],
	[ranking],
	[state],
	[zip]
 FROM [lib://Test data/meetupcom\cities.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);

