	[category.shortname],
	[city_id],
	[city],
	[country],
	[created],
	[description],
	[group_photo.base_url],
	[group_photo.highres_link],
	[group_photo.photo_id],
	[group_photo.photo_link],
	[group_photo.thumb_link],
	[group_photo.type],
	[join_mode],
	[lat],
	[link],
	[lon],
	[members],
	[group_name],
	[organizer.member_id],
	[organizer.name],
	[organizer.photo.base_url],
	[organizer.photo.highres_link],
	[organizer.photo.photo_id],
	[organizer.photo.photo_link],
	[organizer.photo.thumb_link],
	[organizer.photo.type],
	[rating],
	[state],
	[timezone],
	[urlname],
	[utc_offset],
	[visibility],
	[who]
 FROM [lib://Test data/meetupcom\groups.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);

[categories]:
LOAD
	[category_id],
	[category_name],
	[shortname],
	[sort_name]
 FROM [lib://Test data/meetupcom\categories.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);

[members]:
LOAD
	[member_id],
	[bio],
	[city],
	[country] AS [members.country],
	[hometown],
	[joined],
	[lat] AS [members.lat],
	[link] AS [members.link],
	[lon] AS [members.lon],
	[member_name],
	[state] AS [members.state],
	[member_status],
	[visited],
	[group_id],
	APPLYMAP( '__cityKey2GeoPoint', APPLYMAP( '__countryCodeAndCityName2Key', APPLYMAP( '__countryName2IsoThree', LOWER([country])) & LOWER([city])), '-') AS [members.city_GeoInfo],
	APPLYMAP( '__countryCodeIsoThree2Polygon', APPLYMAP( '__countryName2IsoThree', LOWER([country])), '-') AS [members.members.country_GeoInfo];
LOAD
	[member_id],
	[bio],
	[city],
	[country],
	[hometown],
	[joined],
	[lat],
	[link],
	[lon],
	[member_name],
	[state],
	[member_status],
	[visited],
	[group_id]
 FROM [lib://Test data/meetupcom\members.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);

[topics]:
LOAD
	[topic_id],
	[description] AS [topics.description],
	[link] AS [topics.link],
	[members] AS [topics.members],
	[topic_name],
	[urlkey],
	[main_topic_id];
LOAD
	[topic_id],
	[description],
	[link],
	[members],
	[topic_name],
	[urlkey],
	[main_topic_id]
 FROM [lib://Test data/meetupcom\topics.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);

[groups_topics]:
LOAD
	[topic_id],
	[topic_key],
	[topic_name] AS [groups_topics.topic_name],
	[group_id];
LOAD
	[topic_id],
	[topic_key],
	[topic_name],
	[group_id]
 FROM [lib://Test data/meetupcom\groups_topics.csv]
(txt, codepage is 28591, embedded labels, delimiter is ',', msq);



TAG FIELD [venue.country] WITH '$geoname', '$relates_events.venue.country_GeoInfo';
TAG FIELD [events.venue.country_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_venue.country';
TAG FIELD [venue.localized_country_name] WITH '$geoname', '$relates_events.venue.localized_country_name_GeoInfo';
TAG FIELD [events.venue.localized_country_name_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_venue.localized_country_name';

TAG FIELD [country] WITH '$geoname', '$relates_venues.country_GeoInfo';
TAG FIELD [venues.country_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_country';
TAG FIELD [localized_country_name] WITH '$geoname', '$relates_venues.localized_country_name_GeoInfo';
TAG FIELD [venues.localized_country_name_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_localized_country_name';
TAG FIELD [venue_name] WITH '$geoname', '$relates_venues.venue_name_GeoInfo';
TAG FIELD [venues.venue_name_GeoInfo] WITH '$geopoint', '$hidden', '$relates_venue_name';

TAG FIELD [cities.city] WITH '$geoname', '$relates_cities.cities.city_GeoInfo';
TAG FIELD [cities.cities.city_GeoInfo] WITH '$geopoint', '$hidden', '$relates_cities.city';
TAG FIELD [cities.country] WITH '$geoname', '$relates_cities.cities.country_GeoInfo';
TAG FIELD [cities.cities.country_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_cities.country';
TAG FIELD [cities.localized_country_name] WITH '$geoname', '$relates_cities.cities.localized_country_name_GeoInfo';
TAG FIELD [cities.cities.localized_country_name_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_cities.localized_country_name';

TAG FIELD [groups.city] WITH '$geoname', '$relates_groups.groups.city_GeoInfo';
TAG FIELD [groups.groups.city_GeoInfo] WITH '$geopoint', '$hidden', '$relates_groups.city';
TAG FIELD [groups.country] WITH '$geoname', '$relates_groups.groups.country_GeoInfo';
TAG FIELD [groups.groups.country_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_groups.country';

TAG FIELD [city] WITH '$geoname', '$relates_members.city_GeoInfo';
TAG FIELD [members.city_GeoInfo] WITH '$geopoint', '$hidden', '$relates_city';
TAG FIELD [members.country] WITH '$geoname', '$relates_members.members.country_GeoInfo';
TAG FIELD [members.members.country_GeoInfo] WITH '$geopolygon', '$hidden', '$relates_members.country';

DROP TABLES __countryAliasesBase, __countryGeoBase, __cityAliasesBase, __cityGeoBase;
[autoCalendar]: 
  DECLARE FIELD DEFINITION Tagged ('$date')
FIELDS
  Dual(Year($1), YearStart($1)) AS [Year] Tagged ('$axis', '$year'),
  Dual('Q'&Num(Ceil(Num(Month($1))/3)),Num(Ceil(NUM(Month($1))/3),00)) AS [Quarter] Tagged ('$quarter', '$cyclic'),
  Dual(Year($1)&'-Q'&Num(Ceil(Num(Month($1))/3)),QuarterStart($1)) AS [YearQuarter] Tagged ('$yearquarter', '$qualified'),
  Dual('Q'&Num(Ceil(Num(Month($1))/3)),QuarterStart($1)) AS [_YearQuarter] Tagged ('$yearquarter', '$hidden', '$simplified'),
  Month($1) AS [Month] Tagged ('$month', '$cyclic'),
  Dual(Year($1)&'-'&Month($1), monthstart($1)) AS [YearMonth] Tagged ('$axis', '$yearmonth', '$qualified'),
  Dual(Month($1), monthstart($1)) AS [_YearMonth] Tagged ('$axis', '$yearmonth', '$simplified', '$hidden'),
  Dual('W'&Num(Week($1),00), Num(Week($1),00)) AS [Week] Tagged ('$weeknumber', '$cyclic'),
  Date(Floor($1)) AS [Date] Tagged ('$axis', '$date', '$qualified'),
  Date(Floor($1), 'D') AS [_Date] Tagged ('$axis', '$date', '$hidden', '$simplified'),
  If (DayNumberOfYear($1) <= DayNumberOfYear(Today()), 1, 0) AS [InYTD] ,
  Year(Today())-Year($1) AS [YearsAgo] ,
  If (DayNumberOfQuarter($1) <= DayNumberOfQuarter(Today()),1,0) AS [InQTD] ,
  4*Year(Today())+Ceil(Month(Today())/3)-4*Year($1)-Ceil(Month($1)/3) AS [QuartersAgo] ,
  Ceil(Month(Today())/3)-Ceil(Month($1)/3) AS [QuarterRelNo] ,
  If(Day($1)<=Day(Today()),1,0) AS [InMTD] ,
  12*Year(Today())+Month(Today())-12*Year($1)-Month($1) AS [MonthsAgo] ,
  Month(Today())-Month($1) AS [MonthRelNo] ,
  If(WeekDay($1)<=WeekDay(Today()),1,0) AS [InWTD] ,
  (WeekStart(Today())-WeekStart($1))/7 AS [WeeksAgo] ,
  Week(Today())-Week($1) AS [WeekRelNo] ;

DERIVE FIELDS FROM FIELDS [created], [group.created], [event_time], [updated], [groups.created], [joined], [visited] USING [autoCalendar] ;
///$tab Geotag
TAG FIELDS [venue_name] WITH $geoname;


///$tab Signal job done


call Healthcheck('$(vHealthcheckUUID)')


